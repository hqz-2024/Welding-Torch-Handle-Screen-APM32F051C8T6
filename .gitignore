# ============================================================
# Keil MDK — 编译产物 & 用户特定文件
# ============================================================

# Keil 工程选项（用户特定，含断点/窗口布局等本地配置）
*.uvguix.*
*.uvoptx

# Keil 编译中间文件
*.o
*.d
*.crf
*.dep

# Keil 输出产物
*.axf
*.hex
*.elf
*.bin

# Keil 输出的 Listings（反汇编/内存映射）
*.lst
*.map

# Keil 输出目录
**/Out/
**/Listings/
**/OBJ/

# Keil 链接/构建中间产物
*.build_log.htm
*.lnp
*.sct
*.Bak
*.iex

# RTE 运行时环境（自动生成）
RTE/

# J-Link 调试器本地配置
JLinkSettings.ini

# Event Recorder stub（Keil 调试组件）
EventRecorderStub.scvd

# Keil DFP 安装包（SDK 已有解压源码，无需上传包）
*.pack

# ============================================================
# IAR EWARM — 编译产物
# ============================================================

# IAR 工程文件（自动生成，无需版本控制）
*.ewp
*.eww

# IAR 输出目录
**/Debug/
**/Release/

# IAR 编译中间文件
*.pbi
*.xcl

# IAR 输出产物
*.out
*.sim

# ============================================================
# Eclipse CDT / GCC ARM Embedded — 编译产物
# ============================================================

# Eclipse 输出目录
**/Debug/
**/Release/

# GCC 编译产物
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.lst

